FROM python:3.14-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl \
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN git config --global user.email "hadron@collide.dev" && \
    git config --global user.name "Hadron Pipeline"

COPY pyproject.toml alembic.ini ./
COPY src/ src/
RUN pip install --no-cache-dir ".[gemini,openai,opencode]"

# Install opencode CLI (pre-built binary for agent delegation to local LLMs)
RUN curl -fsSL https://opencode.ai/install | bash

# E2E execution lives in a dedicated runner pod (image `hadron-e2e-runner`),
# so the worker image stays lean: no Chromium, no Playwright browsers. Node
# stays because non-E2E agent tooling (e.g. npm-based test commands) uses it.

RUN mkdir -p /workspace
ENV HADRON_WORKSPACE_DIR=/workspace

ENTRYPOINT ["python", "-m", "hadron.worker.main"]
