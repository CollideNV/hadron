FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN git config --global user.email "hadron@collide.dev" && \
    git config --global user.name "Hadron Pipeline"

COPY pyproject.toml alembic.ini ./
COPY src/ src/
RUN pip install --no-cache-dir ".[gemini,openai]"

# Install Playwright with Chromium and its system deps so E2E tests
# can run inside the worker pod without a browser sidecar.
RUN npx playwright install --with-deps chromium

RUN mkdir -p /workspace
ENV HADRON_WORKSPACE_DIR=/workspace

ENTRYPOINT ["python", "-m", "hadron.worker.main"]
